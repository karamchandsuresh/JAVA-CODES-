public class ControlStatements {
    public static void main(String[] args) {
        for (int i = 1; i <= 10; i++) {
            if (i == 3) {
                continue; // Skips 3
            }
            if (i > 5) {
                break; // Stops the loop after 5
            }
            System.out.print(i + " ");
        }
    }
}
