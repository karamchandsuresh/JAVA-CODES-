public class WhileLoops {
    public static void main(String[] args) {
        // While Loop
        System.out.println("Using while loop:");
        int i = 1;
        while (i <= 5) {
            System.out.print(i + " ");
            i++;
        }

        // Do-While Loop
        System.out.println("\nUsing do-while loop:");
        int j = 1;
        do {
            System.out.print(j + " ");
            j++;
        } while (j <= 5);
    }
}
